---
import Layout from "@/layouts/Layout.astro";
import { getSafeCurrentLocale, getTranslations } from "@/utils/i18n";
import { team } from "@/utils/team";
import { Image } from "astro:assets";

const currentLocale = getSafeCurrentLocale(Astro.currentLocale);
const t = getTranslations(currentLocale);
const p = t.profiles;
const farouk = team.farouk;
const achraf = team.achraf;

const sectionRule = "border-t border-border/90";
---

<Layout title={t.meta.title} description={t.meta.description}>
  <main class="w-full">
    <section class="relative overflow-hidden" aria-labelledby="hero-heading">
      <div
        class="pointer-events-none absolute inset-0 opacity-[0.35]"
        aria-hidden="true"
        style={{
          backgroundImage: `
            radial-gradient(circle at 50% 35%, rgb(79 142 247 / 0.09) 0%, transparent 55%),
            linear-gradient(rgba(13 13 15 / 0.035) 1px, transparent 1px),
            linear-gradient(90deg, rgba(13 13 15 / 0.035) 1px, transparent 1px)`,
          backgroundSize: "100% 100%, 32px 32px, 32px 32px",
        }}
      >
      </div>
      <div class="container-consulting section-spacing relative">
        <h1
          id="hero-heading"
          class="text-foreground max-w-3xl text-3xl font-bold tracking-tight sm:text-4xl md:text-[2.35rem]"
        >
          {t.hero.headline}
        </h1>
        <p
          class="text-muted-foreground mt-6 max-w-2xl text-base leading-[1.65] sm:text-lg"
        >
          {t.hero.subline}
        </p>
      </div>
    </section>

    <section
      id="farouk"
      class:list={[sectionRule, "scroll-mt-24"]}
      aria-labelledby="farouk-heading"
    >
      <div
        class="container-consulting section-spacing grid gap-12 md:grid-cols-2 md:gap-14"
      >
        <div class="flex flex-col gap-6">
          <Image
            src={farouk.image}
            alt={p.farouk.name}
            class="border-border aspect-square w-full max-w-xs rounded-lg border object-cover"
            widths={[320, 480, 640]}
            sizes="(max-width: 768px) 100vw, 320px"
          />
          <div>
            <h2
              id="farouk-heading"
              class="text-foreground text-2xl font-bold tracking-tight"
            >
              {p.farouk.name}
            </h2>
            <p class="text-primary mt-1 text-sm font-semibold tracking-wide">
              {p.farouk.title}
            </p>
          </div>
          <div
            class="text-muted-foreground space-y-4 text-sm leading-[1.65] sm:text-base"
          >
            {p.farouk.bio.map((para) => <p>{para}</p>)}
          </div>
          <ul
            class="border-primary/70 text-muted-foreground space-y-2 border-l-2 py-0.5 pl-4 text-sm sm:text-base"
          >
            {p.farouk.credentials.map((line) => <li>{line}</li>)}
          </ul>
          <div class="border-border bg-card/90 rounded-lg border p-4">
            <p class="text-muted-foreground text-sm leading-relaxed">
              {p.farouk.contactCta}
            </p>
            <a
              href={`mailto:${farouk.email}`}
              class="text-muted-foreground hover:text-primary mt-3 inline-flex items-center gap-2 text-sm font-medium transition-colors"
            >
              <svg
                class="h-4 w-4 shrink-0"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
              >
                <path
                  d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
                ></path>
                <polyline points="22,6 12,13 2,6"></polyline>
              </svg>
              {p.linkEmail}
            </a>
          </div>
          <div class="flex flex-wrap gap-4 text-sm">
            <a
              href={farouk.url}
              target="_blank"
              rel="noopener noreferrer"
              class="text-muted-foreground hover:text-primary inline-flex items-center gap-2 transition-colors"
            >
              <svg
                class="h-4 w-4 shrink-0"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
              >
                <path
                  d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                ></path>
              </svg>
              {p.linkLinkedin}
            </a>
            <a
              href={farouk.github}
              target="_blank"
              rel="noopener noreferrer"
              class="text-muted-foreground hover:text-primary inline-flex items-center gap-2 transition-colors"
            >
              <svg
                class="h-4 w-4 shrink-0"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
              >
                <path
                  d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
                ></path>
              </svg>
              {p.linkGithub}
            </a>
          </div>
        </div>
        <div class="flex flex-col gap-6">
          <p
            class="text-primary text-xs font-semibold tracking-[0.14em] uppercase"
          >
            {p.servicesLabel}
          </p>
          <ul class="flex flex-col gap-3">
            {
              p.farouk.services.map((item) => (
                <li class="expertise-card border-border bg-card rounded-lg border px-4 py-4">
                  <h3 class="text-foreground text-base font-semibold">
                    {item.name}
                  </h3>
                  <p class="text-muted-foreground mt-2 text-sm leading-relaxed">
                    {item.description}
                  </p>
                </li>
              ))
            }
          </ul>
          <ul class="flex flex-wrap gap-2">
            {p.farouk.skillTags.map((tag) => <li class="skill-chip">{tag}</li>)}
          </ul>
        </div>
      </div>
    </section>

    <section
      id="achraf"
      class:list={[sectionRule, "scroll-mt-24"]}
      aria-labelledby="achraf-heading"
    >
      <div
        class="container-consulting section-spacing grid gap-12 md:grid-cols-2 md:gap-14"
      >
        <div class="order-2 flex flex-col gap-6 md:order-1">
          <p
            class="text-primary text-xs font-semibold tracking-[0.14em] uppercase"
          >
            {p.servicesLabel}
          </p>
          <ul class="flex flex-col gap-3">
            {
              p.achraf.services.map((item) => (
                <li class="expertise-card border-border bg-card rounded-lg border px-4 py-4">
                  <h3 class="text-foreground text-base font-semibold">
                    {item.name}
                  </h3>
                  <p class="text-muted-foreground mt-2 text-sm leading-relaxed">
                    {item.description}
                  </p>
                </li>
              ))
            }
          </ul>
          <ul class="flex flex-wrap gap-2">
            {p.achraf.skillTags.map((tag) => <li class="skill-chip">{tag}</li>)}
          </ul>
        </div>
        <div class="order-1 flex flex-col gap-6 md:order-2">
          <Image
            src={achraf.image}
            alt={p.achraf.name}
            class="border-border aspect-square w-full max-w-xs rounded-lg border object-cover"
            widths={[320, 480, 640]}
            sizes="(max-width: 768px) 100vw, 320px"
          />
          <div>
            <h2
              id="achraf-heading"
              class="text-foreground text-2xl font-bold tracking-tight"
            >
              {p.achraf.name}
            </h2>
            <p class="text-primary mt-1 text-sm font-semibold tracking-wide">
              {p.achraf.title}
            </p>
          </div>
          <div
            class="text-muted-foreground space-y-4 text-sm leading-[1.65] sm:text-base"
          >
            {p.achraf.bio.map((para) => <p>{para}</p>)}
          </div>
          <ul
            class="border-primary/70 text-muted-foreground space-y-2 border-l-2 py-0.5 pl-4 text-sm sm:text-base"
          >
            {p.achraf.credentials.map((line) => <li>{line}</li>)}
          </ul>
          <div class="border-border bg-card/90 rounded-lg border p-4">
            <p class="text-muted-foreground text-sm leading-relaxed">
              {p.achraf.contactCta}
            </p>
            <a
              href={`mailto:${achraf.email}`}
              class="text-muted-foreground hover:text-primary mt-3 inline-flex items-center gap-2 text-sm font-medium transition-colors"
            >
              <svg
                class="h-4 w-4 shrink-0"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
              >
                <path
                  d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
                ></path>
                <polyline points="22,6 12,13 2,6"></polyline>
              </svg>
              {p.linkEmail}
            </a>
          </div>
          <div class="flex flex-wrap gap-4 text-sm">
            <a
              href={achraf.url}
              target="_blank"
              rel="noopener noreferrer"
              class="text-muted-foreground hover:text-primary inline-flex items-center gap-2 transition-colors"
            >
              <svg
                class="h-4 w-4 shrink-0"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
              >
                <path
                  d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                ></path>
              </svg>
              {p.linkLinkedin}
            </a>
            <a
              href={achraf.github}
              target="_blank"
              rel="noopener noreferrer"
              class="text-muted-foreground hover:text-primary inline-flex items-center gap-2 transition-colors"
            >
              <svg
                class="h-4 w-4 shrink-0"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
              >
                <path
                  d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
                ></path>
              </svg>
              {p.linkGithub}
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>
