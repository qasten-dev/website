---
import FaviconLinks from "@/components/FaviconLinks.astro";
import LanguageButton from "@/components/LanguageButton.astro";
import "@/styles/global.css";
import { getSafeCurrentLocale, getTranslations } from "@/utils/i18n";
import { getRelativeLocaleUrl } from "astro:i18n";
import path from "path";

const currentLocale = getSafeCurrentLocale(Astro.currentLocale);
const t = getTranslations(currentLocale);

const homePath = getRelativeLocaleUrl(currentLocale, "/");

function anchor(id: string) {
  const base = homePath.replace(/\/$/, "");
  if (!base) {
    return `/#${id}`;
  }
  return `${base}#${id}`;
}

const {
  title = t.meta.title,
  description = t.meta.description,
  openGraphMetadata,
  author,
} = Astro.props;

const openGraphImageURL = new URL(
  openGraphMetadata?.imageRelativePath ?? "/qasten-16x9.png",
  Astro.site,
).toString();

const fontFilesGlob = import.meta.glob("/public/fonts/*.woff2", {
  eager: true,
  query: "?url",
  import: "default",
});
const fontFiles = Object.keys(fontFilesGlob).map((file) => path.basename(file));

const linkedInCompany = "https://www.linkedin.com/company/qasten";
---

<!doctype html>
<html lang={currentLocale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:type" content={openGraphMetadata?.type ?? "website"} />
    <meta property="og:site_name" content="Qasten" />
    <meta
      property="og:locale"
      content={currentLocale === "fr" ? "fr_FR" : "en_US"}
    />
    <meta property="og:image" content={openGraphImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="675" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@Qastencom" />
    {author && <meta name="author" content={author} />}

    <FaviconLinks />

    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    {
      fontFiles.map((file) => (
        <link
          rel="preload"
          href={`/fonts/${file}`}
          as="font"
          type="font/woff2"
          crossorigin
        />
      ))
    }

    <title>{title}</title>

    {
      import.meta.env.PROD && (
        <script
          defer
          src="/stats.js"
          data-website-id="519a270a-0b23-4c6e-8109-8697adc1826f"
        />
      )
    }
  </head>

  <body
    class="text-foreground bg-background flex min-h-screen flex-col antialiased"
  >
    <header
      class="border-border/80 bg-background/95 sticky top-0 z-50 border-b backdrop-blur-md"
    >
      <div
        class="container-consulting flex h-14 items-center justify-between gap-3 md:h-16"
      >
        <a
          href={homePath}
          class="text-foreground shrink-0 text-base font-semibold tracking-tight md:text-lg"
        >
          Qasten
        </a>
        <div
          class="flex min-w-0 flex-1 items-center justify-end gap-2 sm:gap-4 md:gap-6"
        >
          <nav class="hidden items-center gap-1 text-sm font-medium sm:flex">
            <a
              href={anchor("farouk")}
              class="text-muted-foreground hover:text-foreground rounded-md px-2 py-1 transition-colors"
            >
              {t.nav.farouk}
            </a>
            <a
              href={anchor("achraf")}
              class="text-muted-foreground hover:text-foreground rounded-md px-2 py-1 transition-colors"
            >
              {t.nav.achraf}
            </a>
            <a
              href={anchor("contact")}
              class="text-muted-foreground hover:text-foreground rounded-md px-2 py-1 transition-colors"
            >
              {t.nav.contact}
            </a>
          </nav>
          <div class="flex shrink-0 items-center gap-1">
            <LanguageButton locale="en" />
            <LanguageButton locale="fr" />
          </div>
        </div>
      </div>
    </header>

    <div class="flex flex-1 flex-col">
      <slot />
    </div>

    <footer class="border-border/80 bg-background border-t">
      <div
        class="container-consulting flex flex-col gap-3 py-8 sm:flex-row sm:items-center sm:justify-between"
      >
        <p class="text-muted-foreground text-sm">{t.footer.copyright}</p>
        <div class="flex flex-wrap items-center gap-4">
          <a
            href={linkedInCompany}
            target="_blank"
            rel="noopener noreferrer"
            class="text-primary text-sm font-medium hover:underline"
          >
            {t.footer.companyLinkedin}
          </a>
          <div class="flex items-center gap-1">
            <LanguageButton locale="en" />
            <LanguageButton locale="fr" />
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
